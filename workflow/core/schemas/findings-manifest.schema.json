{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-workflow-kit.dev/schemas/findings-manifest.schema.json",
  "title": "Open Workflow Kit Findings Snapshot",
  "type": "object",
  "required": ["schema_version", "snapshot_at", "owner", "source", "findings"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "snapshot_at": { "type": "string", "format": "date-time" },
    "owner": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "minLength": 1 },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "priority", "status", "title", "owner"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9._-]{1,127}$" },
          "priority": { "enum": ["P0", "P1", "P2", "P3"] },
          "status": { "enum": ["OPEN", "CLOSED"] },
          "title": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 },
          "closure_evidence": { "type": "string", "minLength": 1 }
        },
        "allOf": [{
          "if": { "properties": { "status": { "const": "CLOSED" } }, "required": ["status"] },
          "then": { "required": ["closure_evidence"] }
        }]
      }
    }
  }
}
